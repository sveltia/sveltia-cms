  advanced:
    title: 進階
    beta:
      title: Beta 測試功能
      description: 啟用某些可能不穩定或尚未本地化的 Beta 功能。
      switch_label: 加入 Beta 測試計劃
    developer_mode:
      title: 開發者模式
      description: 啟用某些面向開發者的功能，包括詳細的控制台日誌與原生右鍵選單。
      switch_label: 啟用開發者模式
    deploy_hook:
      title: 部署勾子 (Deploy Hook)
      description: 輸入 Webhook 網址，當您點擊「發布變更」手動觸發部署時將會呼叫此網址。如果您使用 GitHub Actions，此處可保持空白。
      url:
        field_label: 勾子網址 (Hook URL)
        saved: 勾子網址已儲存。
        removed: 勾子網址已移除。
      auth:
        field_label: Authorization 標頭 (例如 Bearer <token>) (選填)
        saved: Authorization 標頭已儲存。
        removed: Authorization 標頭已移除。
